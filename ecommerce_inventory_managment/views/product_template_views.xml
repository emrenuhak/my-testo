<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_ecommerce" model="ir.ui.view">
        <field name="name">product.template.form.ecommerce.inventory</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="ecommerce_warehouse_ids" widget="many2many_tags"/>
                <field name="ecommerce_stock_qty"/>
            </xpath>
        </field>
    </record>
</odoo>
